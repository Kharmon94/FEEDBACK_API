#!/bin/bash -e

# If running the rails server then create/migrate DB and seed (e.g. admin user)
if [ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:seed
  ./bin/rails stripe:sync_plans || true
  ./bin/rails stripe:sync_plans mode=live || true
fi

exec "${@}"
